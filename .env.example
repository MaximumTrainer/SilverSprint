# Intervals.icu credentials for local development only.
# rename to .env for use, and add your own credentials from Intervals.icu (https://intervals.icu/settings/api)
INTERVALS_ATHLETE_ID=<your_athlete_id_here>
INTERVALS_API_KEY=<your_api_key_here>

# OAuth redirect URI override (optional).
# Set this to the exact URI registered for SilverSprint (client_id 264) in your
# intervals.icu app settings.  Required when the app is served from a URL that
# differs from https://maximumtrainer.github.io/SilverSprint/ — for example a
# Vercel deployment, a custom domain, or local development.
#
# For local development, intervals.icu always allows http://localhost/ (port 80),
# so run `npx serve dist -p 80` after `npm run build` or set this to the exact
# localhost URL you have registered.
#
# Leave this unset for the canonical GitHub Pages deployment — the redirect URI
# is derived automatically from the page URL in that case.
# VITE_OAUTH_REDIRECT_URI=https://maximumtrainer.github.io/SilverSprint/
