# Intervals.icu credentials for local development only.
# rename to .env for use, and add your own credentials from Intervals.icu (https://intervals.icu/settings/api)
INTERVALS_ATHLETE_ID=<your_athlete_id_here>
INTERVALS_API_KEY=<your_api_key_here>

# OAuth redirect URI override (optional).
# By default SilverSprint builds the redirect URI automatically from the
# current page URL (e.g. https://yourdomain.com/callback or
# https://maximumtrainer.github.io/SilverSprint/callback for GitHub Pages).
# Set this variable only when the auto-detected URI does not match the URL
# registered in your Intervals.icu OAuth application settings.
# VITE_OAUTH_REDIRECT_URI=https://yourdomain.com/callback

# OAuth client secret issued by Intervals.icu for the registered OAuth application.
# Required for the authorization-code token exchange (alongside PKCE).
# VITE_OAUTH_CLIENT_SECRET=<your_oauth_client_secret_here>
