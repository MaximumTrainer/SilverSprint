# Intervals.icu credentials for local development only.
# rename to .env for use, and add your own credentials from Intervals.icu (https://intervals.icu/settings/api)
INTERVALS_ATHLETE_ID=<your_athlete_id_here>
INTERVALS_API_KEY=<your_api_key_here>

# OAuth redirect URI override (optional).
# By default SilverSprint builds the redirect URI automatically from the
# current page URL (e.g. https://yourdomain.com/callback or
# https://maximumtrainer.github.io/SilverSprint/callback for GitHub Pages).
# Set this variable only when the auto-detected URI does not match the URL
# registered in your Intervals.icu OAuth application settings.
# VITE_OAUTH_REDIRECT_URI=https://yourdomain.com/callback

# ── OAuth token exchange (choose ONE of the two options below) ───────────────

# OPTION 1 (recommended): Server-side proxy via Vercel.
# The Vercel deployment at /api/oauth/token handles the token exchange using
# OAUTH_CLIENT_SECRET stored as a Vercel environment variable. The GitHub Pages
# frontend calls this endpoint cross-origin.
#
# Steps:
#   1. Deploy the project to Vercel.
#   2. In Vercel project settings, add environment variable:
#        OAUTH_CLIENT_SECRET = <your Intervals.icu OAuth client secret>
#        OAUTH_ALLOWED_ORIGIN = https://maximumtrainer.github.io
#   3. Add GitHub repository secret:
#        VITE_OAUTH_PROXY_URL = https://<your-vercel-deployment>/api/oauth/token
#
# VITE_OAUTH_PROXY_URL=https://<your-vercel-deployment>/api/oauth/token

# OPTION 2 (simpler, less secure): Build-time client secret.
# The secret is embedded in the JavaScript bundle served to browsers.
# Acceptable when the Intervals.icu OAuth app is registered as a public client.
# WARNING: Any VITE_* variable is visible to end users in the browser bundle.
# VITE_OAUTH_CLIENT_SECRET=<your_oauth_client_secret_here>
